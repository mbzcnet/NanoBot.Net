@page "/config/channels"
@inject ISnackbar Snackbar
@inject ILogger<Channels> Logger
@using NanoBot.Core.Configuration
@using NanoBot.Core.Channels
@using NanoBot.WebUI.Components.Channels
@rendermode InteractiveServer

<PageTitle>NanoBot - 通道配置</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="nb-config-page">
    <MudBreadcrumbs Items="_breadcrumbItems" Class="nb-page-breadcrumb" />
    
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h4">通道配置</MudText>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   Class="nb-config-outline-btn"
                   OnClick="RefreshChannels">
            刷新
        </MudButton>
    </div>

    @if (_isLoading)
    {
        <div class="nb-config-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Class="mt-2">正在加载配置...</MudText>
        </div>
    }
    else if (_config == null)
    {
        <MudAlert Severity="Severity.Warning" Class="nb-config-alert">
            <MudText Typo="Typo.h6">配置文件未找到</MudText>
            <MudText Class="mt-2">配置文件路径：<code>@_configPath</code></MudText>
            <MudText Class="mt-2">请先运行以下命令初始化配置：</MudText>
            <MudPaper Class="pa-2 mt-2 nb-code-callout" Elevation="0">
                <code>nbot onboard</code>
            </MudPaper>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Class="mt-4 nb-config-primary-btn"
                       OnClick="CreateDefaultConfig">
                创建默认配置
            </MudButton>
        </MudAlert>
    }
    else
    {
        <MudPaper Elevation="0" Class="pa-4 mb-4 nb-config-card">
            <MudText Typo="Typo.h6" Class="mb-4">全局设置</MudText>
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudCheckBox @bind-Checked="_config.Channels.SendProgress"
                                 Label="发送进度更新"
                                 T="bool"
                                 Class="mb-2" />
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        在执行工具时发送进度更新消息
                    </MudText>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudCheckBox @bind-Checked="_config.Channels.SendToolHints"
                                 Label="发送工具提示"
                                 T="bool"
                                 Class="mb-2" />
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        在工具调用时显示提示信息
                    </MudText>
                </MudItem>
            </MudGrid>
            <MudDivider Class="my-4" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       Class="nb-config-primary-btn"
                       OnClick="SaveGlobalSettings">
                保存全局设置
            </MudButton>
        </MudPaper>
    }

    @if (!_channelsLoading && _config != null)
    {
        <MudGrid>
            @foreach (var channel in _channelCatalog.Entries)
            {
                var isEnabled = _enabledChannels.Contains(channel.Id);
                var meta = _channelRegistry.GetChannelMeta(channel.Id);
                var cardClass = isEnabled ? "nb-channel-card nb-channel-enabled" : "nb-channel-card nb-channel-disabled";

                <MudItem xs="12" md="6">
                    <MudCard Class="@cardClass">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <div class="d-flex align-center justify-space-between">
                                    <div class="d-flex align-center">
                                        @if (!string.IsNullOrEmpty(channel.SystemImage))
                                        {
                                            <MudIcon Icon="@ChannelFormattingService.GetChannelIcon(channel.SystemImage)"
                                                     Class="mr-2"
                                                     Size="Size.Large" />
                                        }
                                        <MudText Typo="Typo.h6">@channel.Label</MudText>
                                    </div>
                                    @if (_config != null)
                                    {
                                        <MudSwitch @bind-Checked="@_channelToggleStates[channel.Id]"
                                                  T="bool"
                                                  Color="Color.Primary"
                                                  OnChange="@((bool enabled) => OnChannelToggleChanged(channel.Id, enabled))" />
                                    }
                                </div>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (meta != null)
                            {
                                <MudText Typo="Typo.body2" Class="mb-2">@meta.Blurb</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                    <strong>类型:</strong> @channel.DetailLabel
                                </MudText>
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Color="@(isEnabled ? Color.Success : Color.Default)"
                                         Class="mt-2">
                                    @(isEnabled ? "已启用" : "未启用")
                                </MudChip>
                            }
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="@(() => EditChannel(channel.Id))">
                                配置
                            </MudButton>
                            @if (isEnabled && _config != null)
                            {
                                <MudButton Size="Size.Small"
                                           Color="Color.Warning"
                                           OnClick="@(() => TestChannel(channel.Id))">
                                    测试连接
                                </MudButton>
                            }
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else if (!_isLoading && _config != null)
    {
        <div class="nb-config-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Class="mt-2">正在加载通道配置...</MudText>
        </div>
    }

    <MudDialog Visible="@_isEditDialogOpen"
               VisibleChanged="OnEditDialogVisibleChanged"
               Options="@_dialogOptions">
        <DialogContent>
            <MudText Typo="Typo.h6" Class="mb-4">配置 @_editingChannel?.Label</MudText>

            @if (_editingChannel != null && _channelConfigRef != null)
            {
                @ChannelConfigRenderer.Render(_editingChannel.Id, _channelConfigRef.Config, obj => { _channelConfigRef.Config = obj; })
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CancelEdit">取消</MudButton>
            <MudButton Color="Color.Primary"
                       Disabled="@(_editingChannel == null)"
                       OnClick="SaveChannelConfig">
                保存
            </MudButton>
        </DialogActions>
    </MudDialog>
</MudContainer>

@code {
    private AgentConfig? _config;
    private string _configPath = string.Empty;
    private bool _isLoading = true;

    private readonly IChannelRegistry _channelRegistry = new ChannelRegistry();
    private ChannelUiCatalog _channelCatalog = new();
    private HashSet<string> _enabledChannels = new();
    private Dictionary<string, bool> _channelToggleStates = new();
    private bool _channelsLoading = true;
    private ChannelUiMetaEntry? _editingChannel;
    private bool _isEditDialogOpen;
    private ChannelConfigRef? _channelConfigRef;

    private List<BreadcrumbItem> _breadcrumbItems = new();
    private DialogOptions _dialogOptions = new() { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };

    protected override void OnInitialized()
    {
        _breadcrumbItems = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("配置", href: "/config"),
            new BreadcrumbItem("通道配置", href: null, disabled: true)
        };
        
        _ = LoadConfigAsync();
    }

    private async Task LoadConfigAsync()
    {
        await Task.Delay(100);
        await LoadConfig();
        await LoadChannels();
    }

    private async Task LoadConfig()
    {
        _isLoading = true;
        StateHasChanged();
        
        try
        {
            _configPath = ConfigPaths.GetAgentConfigPath();
            
            if (File.Exists(_configPath))
                _config = await Task.Run(async () => 
                    await ConfigurationLoader.LoadAsync(_configPath, CancellationToken.None));
            else
                _config = null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"配置加载错误: {ex}");
            await InvokeAsync(() => Snackbar.Add($"加载配置失败: {ex.Message}", Severity.Error));
            _config = null;
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadChannels()
    {
        _channelsLoading = true;
        try
        {
            _channelCatalog = _channelRegistry.GetCatalog();
            
            _enabledChannels.Clear();
            _channelToggleStates.Clear();

            foreach (var channel in _channelCatalog.Entries)
            {
                var isEnabled = _config != null && ChannelFormattingService.IsChannelEnabled(_config, channel.Id);
                if (isEnabled)
                    _enabledChannels.Add(channel.Id);
                _channelToggleStates[channel.Id] = isEnabled;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load channels");
            Snackbar.Add($"加载通道配置失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _channelsLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnChannelToggleChanged(string channelId, bool enabled)
    {
        if (_config == null)
        {
            Snackbar.Add("配置文件未找到", Severity.Error);
            return;
        }

        _config.Channels ??= new ChannelsConfig();

        try
        {
            if (enabled)
            {
                ChannelFormattingService.EnableChannel(_config, channelId);
                _enabledChannels.Add(channelId);
                Snackbar.Add($"已启用 {_channelCatalog.ById[channelId]?.Label}", Severity.Success);
            }
            else
            {
                ChannelFormattingService.DisableChannel(_config, channelId);
                _enabledChannels.Remove(channelId);
                Snackbar.Add($"已禁用 {_channelCatalog.ById[channelId]?.Label}", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to toggle channel");
            Snackbar.Add($"切换通道状态失败: {ex.Message}", Severity.Error);
            await LoadChannels();
        }
    }

    private async Task SaveConfig()
    {
        if (_config == null) return;
        _config.Channels ??= new ChannelsConfig();

        try
        {
            var configDir = Path.GetDirectoryName(_configPath);
            if (!string.IsNullOrEmpty(configDir) && !Directory.Exists(configDir))
                Directory.CreateDirectory(configDir);
            
            await ConfigurationLoader.SaveAsync(_configPath, _config, CancellationToken.None);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存配置失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveGlobalSettings()
    {
        if (_config == null) return;
        _config.Channels ??= new ChannelsConfig();

        try
        {
            await SaveConfig();
            Snackbar.Add("全局设置已保存", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save global settings");
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task RefreshChannels()
    {
        await LoadChannels();
        Snackbar.Add("通道配置已刷新", Severity.Info);
    }

    private void EditChannel(string channelId)
    {
        if (_config == null)
        {
            _config = new AgentConfig
            {
                Name = "NanoBot",
                Workspace = new WorkspaceConfig { Path = ".nbot" },
                Channels = new ChannelsConfig()
            };
        }
        _config.Channels ??= new ChannelsConfig();

        _editingChannel = _channelCatalog.ById.GetValueOrDefault(channelId);
        (_channelConfigRef, _) = ChannelFormattingService.GetChannelEditor(_config, channelId);

        _isEditDialogOpen = _editingChannel != null;
        StateHasChanged();
    }

    private async Task SaveChannelConfig()
    {
        if (_editingChannel == null || _channelConfigRef == null)
        {
            Snackbar.Add("没有要保存的配置", Severity.Warning);
            return;
        }

        if (_config == null)
        {
            Snackbar.Add("配置文件未找到", Severity.Error);
            return;
        }

        _config.Channels ??= new ChannelsConfig();

        try
        {
            ChannelFormattingService.SetChannelConfig(_config, _editingChannel.Id, _channelConfigRef.Config);
            await SaveConfig();
            Snackbar.Add($"{_editingChannel.Label} 配置已保存", Severity.Success);
            _isEditDialogOpen = false;
            _editingChannel = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save channel config");
            Snackbar.Add($"保存配置失败: {ex.Message}", Severity.Error);
        }
    }

    private void CancelEdit()
    {
        _isEditDialogOpen = false;
        _editingChannel = null;
        StateHasChanged();
    }

    private Task OnEditDialogVisibleChanged(bool visible)
    {
        _isEditDialogOpen = visible;
        if (!visible)
            _editingChannel = null;
        return Task.CompletedTask;
    }

    private async Task TestChannel(string channelId)
    {
        if (_config == null)
        {
            Snackbar.Add("配置文件未找到", Severity.Error);
            return;
        }

        var configObj = ChannelFormattingService.GetChannelConfig(_config, channelId);
        if (configObj == null)
        {
            Snackbar.Add("未知渠道", Severity.Warning);
            return;
        }

        var error = ChannelFormattingService.ValidateChannelConfig(configObj, channelId);
        if (error != null)
        {
            Snackbar.Add(error, Severity.Warning);
            return;
        }

        var label = _channelCatalog.ById.GetValueOrDefault(channelId)?.Label ?? channelId;
        Snackbar.Add($"{label} 配置验证通过，请在启动后测试实际连接", Severity.Success);
        await Task.CompletedTask;
    }

    private async Task CreateDefaultConfig()
    {
        try
        {
            var configDir = Path.GetDirectoryName(_configPath);
            if (!string.IsNullOrEmpty(configDir) && !Directory.Exists(configDir))
                Directory.CreateDirectory(configDir);
            
            _config = new AgentConfig
            {
                Name = "NanoBot",
                Workspace = new WorkspaceConfig { Path = ".nbot" },
                Channels = new ChannelsConfig()
            };
            
            await ConfigurationLoader.SaveAsync(_configPath, _config, CancellationToken.None);
            
            Snackbar.Add("默认配置已创建", Severity.Success);
            _isLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"创建配置失败: {ex.Message}", Severity.Error);
        }
    }
}
