    private long GetMaxFileSizeFromConfig()
    {
        try
        {
            var maxFileSizeStr = Configuration["WebUI:Features:MaxFileSize"] ?? "10MB";

            // 解析配置字符串（如 "10MB", "5MB", "1GB" 等）
            maxFileSizeStr = maxFileSizeStr.Trim().ToUpperInvariant();

            if (long.TryParse(maxFileSizeStr, out var bytes))
            {
                return bytes;
            }

            if (maxFileSizeStr.EndsWith("KB", StringComparison.Ordinal))
            {
                var num = double.Parse(maxFileSizeStr[..^2]);
                return (long)(num * 1024);
            }

            if (maxFileSizeStr.EndsWith("MB", StringComparison.Ordinal))
            {
                var num = double.Parse(maxFileSizeStr[..^2]);
                return (long)(num * 1024 * 1024);
            }

            if (maxFileSizeStr.EndsWith("GB", StringComparison.Ordinal))
            {
                var num = double.Parse(maxFileSizeStr[..^2]);
                return (long)(num * 1024 * 1024 * 1024);
            }

            // 默认 10MB
            return 10 * 1024 * 1024;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "无法解析 MaxFileSize 配置，使用默认值 10MB");
            return 10 * 1024 * 1024;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
