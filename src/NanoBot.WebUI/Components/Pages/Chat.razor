@page "/chat/{SessionId}"
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ISessionService SessionService
@inject IAgentService AgentService
@inject ILogger<Chat> Logger
@inject IWebHostEnvironment WebHostEnvironment
@inject IJSRuntime JSRuntime
@inject NanoBot.Core.Storage.IFileStorageService FileStorageService
@inject IConfiguration Configuration
@inject IDebugState DebugState
@using NanoBot.WebUI.Services
@using NanoBot.WebUI.Components.Parts
@using NanoBot.Core.Configuration
@using NanoBot.Core.Messages
@using NanoBot.Core.Sessions
@using NanoBot.Cli.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.Extensions.Configuration
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>NanoBot - 聊天</PageTitle>

<div class="nb-chat-page">
    <div class="nb-chat-shell">
        
        <div @ref="_messagesContainerRef" style="flex:1;min-height:0;overflow:auto;">
            <div class="nb-chat-content" style="max-width: 1500px; margin: 0 auto;">
                <div class="nb-chat-header">
                    <MudButton Variant="Variant.Text"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               Class="nb-new-chat-btn"
                               OnClick="StartNewChat"
                               Disabled="@_isGenerating">
                        新對話
                    </MudButton>
                </div>
                @if (_messages == null || !_messages.Any())
                {
                    <div class="nb-chat-empty">
                        <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Size="Size.Medium" Class="mb-2" />
                        <MudText Typo="Typo.h6">开始对话吧</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">提出一个目标，NanoBot 会逐步完成。</MudText>
                    </div>
                }
                else
                {
                    @foreach (var message in _messages)
                    {
                        <div class="nb-message-row nb-message-row-@message.Role.ToLower()">
                            <div class="nb-message-bubble nb-message-bubble-@message.Role.ToLower()">
                                @if (message.Role.ToLower() != "user")
                                {
                                    <div class="nb-message-header">
                                        <MudIcon Icon="@GetMessageIcon(message.Role)" Size="Size.Small" Class="mr-2" />
                                        <MudText Typo="Typo.caption">@GetMessageSender(message.Role)</MudText>
                                    </div>
                                }

                                @* OpenCode 风格：按 Parts 顺序交错渲染（文本与工具交替显示） *@
                                @if (message.HasSessionParts)
                                {
                                    @* 使用有序 Parts 渲染 *@
                                    @foreach (var part in message.SessionParts!)
                                    {
                                        @switch (part.Type)
                                        {
                                            case "text" when !string.IsNullOrWhiteSpace(part.Text):
                                                <div class="nb-part-text">
                                                    <MarkdownRenderer Content="@part.Text" />
                                                </div>
                                                break;
                                            case "tool_call":
                                                <div class="nb-tool-execution-card">
                                                    <div class="nb-tool-io-header nb-tool-io-header-in">
                                                        <MudIcon Icon="@Icons.Material.Filled.Input" Size="Size.Small" Class="mr-1" />
                                                        <span>IN</span>
                                                        <span class="nb-tool-io-name">@part.ToolName</span>
                                                    </div>
                                                    <div class="nb-tool-io-body">
                                                        <pre><code>@FormatToolPayload(part.Arguments ?? "{}")</code></pre>
                                                    </div>
                                                </div>
                                                break;
                                            case "tool_result":
                                                <div class="@($"nb-tool-execution-card {(part.IsError ? "nb-tool-error" : "")}")">
                                                    <div class="@($"nb-tool-io-header {(part.IsError ? "nb-tool-io-header-error" : "nb-tool-io-header-out")}")">
                                                        <MudIcon Icon="@(part.IsError ? Icons.Material.Filled.ErrorOutline : Icons.Material.Filled.Output)" Size="Size.Small" Class="mr-1" />
                                                        <span>OUT</span>
                                                    </div>
                                                    <div class="nb-tool-io-body">
                                                        @if (ShouldRenderToolOutputAsMarkdown(part.Output ?? ""))
                                                        {
                                                            <div class="nb-tool-io-markdown">
                                                                <MarkdownRenderer Content="@FormatToolOutput(part.Output ?? "")" />
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <pre><code>@FormatToolOutput(part.Output ?? "")</code></pre>
                                                        }
                                                    </div>
                                                </div>
                                                break;
                                        }
                                    }
                                }
                                else if (message.ToolExecutions.Any())
                                {
                                    @* 传统渲染方式：先工具执行列表，再文本内容 *@
                                    <div class="nb-tool-execution-list">
                                        @foreach (var toolExecution in message.ToolExecutions)
                                        {
                                            <div class="nb-tool-execution-card">
                                                <div class="nb-tool-io-header nb-tool-io-header-in">
                                                    <MudIcon Icon="@Icons.Material.Filled.Input" Size="Size.Small" Class="mr-1" />
                                                    <span>IN</span>
                                                    <span class="nb-tool-io-name">@toolExecution.Name</span>
                                                </div>
                                                <div class="nb-tool-io-body">
                                                    <pre><code>@FormatToolPayload(toolExecution.Arguments)</code></pre>
                                                </div>

                                                <div class="@($"nb-tool-io-header {(toolExecution.IsError ? "nb-tool-io-header-error" : "nb-tool-io-header-out")}")">
                                                    <MudIcon Icon="@(toolExecution.IsError ? Icons.Material.Filled.ErrorOutline : Icons.Material.Filled.Output)" Size="Size.Small" Class="mr-1" />
                                                    <span>OUT</span>
                                                </div>
                                                <div class="nb-tool-io-body">
                                                    @if (ShouldRenderToolOutputAsMarkdown(toolExecution.Output))
                                                    {
                                                        <div class="nb-tool-io-markdown">
                                                            <MarkdownRenderer Content="@FormatToolOutput(toolExecution.Output)" />
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <pre><code>@FormatToolOutput(toolExecution.Output)</code></pre>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    @* 显示消息内容 *@
                                    @if (message.Parts?.Any() == true)
                                    {
                                        @* 使用 Part 组件渲染 *@
                                        @foreach (var part in message.Parts)
                                        {
                                            <MessagePartComponent Part="part" />
                                        }
                                    }
                                    else if (!string.IsNullOrEmpty(message.Content))
                                    {
                                        @* 回退到 Markdown 渲染 *@
                                        <MarkdownRenderer Content="@message.Content" />
                                    }
                                }
                                else
                                {
                                    @* 无工具执行，仅显示文本内容 *@
                                    @if (!string.IsNullOrEmpty(message.Content))
                                    {
                                        <MarkdownRenderer Content="@message.Content" />
                                    }
                                }

                                @if (message.Role.Equals("user", StringComparison.OrdinalIgnoreCase) ||
                                     message.Role.Equals("assistant", StringComparison.OrdinalIgnoreCase))
                                {
                                    <div class="nb-message-actions-wrapper">
                                        <div class="nb-message-actions-container">
                                            <MessageActions IsUserMessage="@message.Role.Equals("user", StringComparison.OrdinalIgnoreCase)"
                                                            OnCopy="@(() => CopyMessage(message))"
                                                            OnEdit="@(() => EditMessage(message))"
                                                            OnRetry="@(() => RetryMessage(message))"
                                                            OnDelete="@(() => DeleteMessage(message))" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }

                @if (_isGenerating)
                {
                    <div class="nb-message-row nb-message-row-assistant">
                        <div class="nb-message-bubble nb-message-bubble-assistant">
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">AI 正在思考...</MudText>
                        </div>
                    </div>
                }

                <div @ref="_messagesEndRef"></div>
            </div>
        </div>

        <div @ref="_inputAreaRef" class="nb-composer-container">
            <div class="nb-composer-shell">
                <div class="nb-composer-main">
                    <MudTextField @bind-Value="_inputMessage"
                                  Placeholder="输入消息... (Shift+Enter 换行)"
                                  Variant="Variant.Text"
                                  Lines="3"
                                  MaxLines="8"
                                  AutoGrow="true"
                                  Class="nb-composer-input"
                                  Disabled="@_isGenerating"
                                  OnKeyDown="HandleKeyDown"
                                  Immediate="true" />
                </div>
                <div class="nb-composer-toolbar">
                    <div class="nb-composer-left">
                        <label for="chat-image-upload" class="@($"nb-action-btn{(_isGenerating ? " disabled" : string.Empty)}")">
                            <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                        </label>
                        <InputFile id="chat-image-upload"
                                   OnChange="HandleImageSelected"
                                   accept="image/*"
                                   disabled="@_isGenerating"
                                   style="display:none" />
                        <MudSelect T="string"
                                   Value="@(_selectedProfileId ?? string.Empty)"
                                   ValueChanged="SelectProfile"
                                   Dense="true"
                                   Variant="Variant.Text"
                                   Class="nb-model-select"
                                   AdornmentIcon="@Icons.Material.Filled.ExpandMore"
                                   AnchorOrigin="Origin.BottomLeft"
                                   TransformOrigin="Origin.TopLeft">
                            @if (_profileOptions.Any())
                            {
                                @foreach (var option in _profileOptions)
                                {
                                    <MudSelectItem T="string" Value="@option.ProfileId">@option.Display</MudSelectItem>
                                }
                            }
                            else
                            {
                                <MudSelectItem T="string" Value="@string.Empty" Disabled="true">未找到可用模型</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                    <div class="nb-composer-right">
                        @if (_isGenerating)
                        {
                            <div class="nb-send-btn"
                                 @onclick="StopGeneration">
                                <MudIcon Icon="@Icons.Material.Filled.Stop" Size="Size.Small" />
                            </div>
                        }
                        else
                        {
                            <div class="@($"nb-send-btn{((string.IsNullOrWhiteSpace(_inputMessage) && string.IsNullOrWhiteSpace(_attachedImageUrl)) ? " mud-disabled" : string.Empty)}")"
                                 @onclick="SendMessage">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" />
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_attachedImageUrl))
                {
                    <div class="mt-2 px-1">
                        <div class="d-flex align-center gap-2">
                            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">
                                已附加图片
                            </MudChip>
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Close"
                                       OnClick="RemoveAttachedImage"
                                       Class="px-1">
                                移除
                            </MudButton>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_attachedImageUrl))
                {
                    <MudPaper Elevation="1" Outlined="true" Class="pa-2 mt-2" Style="width: fit-content;">
                        <img src="@_attachedImageUrl" alt="preview" style="max-width: 180px; max-height: 180px;" />
                    </MudPaper>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string SessionId { get; set; } = string.Empty;

    private List<ChatMessage> _messages = new();
    private string _inputMessage = string.Empty;
    private bool _isGenerating = false;
    private ElementReference _messagesContainerRef;
    private ElementReference _messagesEndRef;
    private ElementReference _inputAreaRef;
    private CancellationTokenSource? _cancellationTokenSource;
    private string? _attachedImageUrl;
    private DotNetObjectReference<Chat>? _dotNetRef;
    private bool _pasteRegistered;
    private readonly List<ProfileOption> _profileOptions = new();
    private string? _selectedProfileId;

    protected override async Task OnInitializedAsync()
    {
        _cancellationTokenSource = new CancellationTokenSource();

        // Check for debug=1 query parameter and enable debug mode
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        if (HttpUtility.ParseQueryString(uri.Query).Get("debug") == "1")
        {
            var sessionKey = $"chat_{SessionId}";
            DebugState.EnableDebug(sessionKey);
        }

        await LoadProfileOptionsAsync();
        await LoadMessages();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadProfileOptionsAsync();
        await LoadMessages();
    }
    
    public async ValueTask DisposeAsync()
    {
        _cancellationTokenSource?.Dispose();
        _dotNetRef?.Dispose();

        if (_pasteRegistered)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("nanoBotChatImage.detachPasteHandler", _inputAreaRef);
            }
            catch
            {
                // ignore
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("nanoBotChatImage.attachPasteHandler", _inputAreaRef, _dotNetRef);
            _pasteRegistered = true;
            await ScrollToBottom();
        }
    }

    private async Task LoadMessages()
    {
        var messages = await SessionService.GetMessagesAsync(SessionId);
        _messages = messages.Select(m => new ChatMessage
        {
            Id = m.Id,
            Role = m.Role,
            Content = m.Content,
            Timestamp = m.Timestamp,
            ToolCall = m.ToolCall,
            ToolExecutions = m.ToolExecutions.Select(t => new ChatToolExecution
            {
                CallId = t.CallId,
                Name = t.Name,
                Arguments = t.Arguments,
                Output = t.Output,
                IsError = t.IsError
            }).ToList(),
            SourceIndex = m.SourceIndex,
            RetryFromIndex = m.RetryFromIndex,
            RetryPrompt = m.RetryPrompt,
            SessionParts = m.Parts  // 加载有序 Parts 用于交错渲染
        }).ToList();

        // 自动滚动到底部
        await Task.Yield();
        await ScrollToBottom();
    }

    private async Task LoadProfileOptionsAsync()
    {
        try
        {
            var configPath = GetConfigPath();
            if (!File.Exists(configPath))
            {
                _profileOptions.Clear();
                _selectedProfileId = null;
                return;
            }

            var config = await ConfigurationLoader.LoadAsync(configPath, CancellationToken.None);
            _profileOptions.Clear();
            foreach (var profile in config.Llm.Profiles)
            {
                var displayName = profile.Value.GetDisplayName();
                _profileOptions.Add(new ProfileOption(
                    profile.Key,
                    $"{displayName} ({profile.Value.Model})"));
            }

            var session = await SessionService.GetSessionAsync(SessionId);
            var preferredProfileId = session?.ProfileId
                                     ?? config.Llm.DefaultProfile
                                     ?? _profileOptions.FirstOrDefault()?.ProfileId;

            if (string.IsNullOrWhiteSpace(preferredProfileId))
            {
                _selectedProfileId = null;
                return;
            }

            _selectedProfileId = preferredProfileId;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load profile options for chat");
        }
    }

    private async Task SelectProfile(string profileId)
    {
        _selectedProfileId = profileId;
        var selected = _profileOptions.FirstOrDefault(p => p.ProfileId == profileId);
        var displayLabel = selected?.Display ?? profileId;

        try
        {
            await SessionService.SetSessionProfileAsync(SessionId, profileId);
            Snackbar.Add($"已切换模型：{displayLabel}", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to set session profile for chat");
            Snackbar.Add($"切换模型失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_inputMessage) && string.IsNullOrWhiteSpace(_attachedImageUrl))
            return;

        var textPart = _inputMessage.Trim();
        var imagePart = string.IsNullOrWhiteSpace(_attachedImageUrl) ? string.Empty : $"\n\n![图片]({_attachedImageUrl})";
        var userContent = $"{textPart}{imagePart}".Trim();
        _inputMessage = string.Empty;
        _attachedImageUrl = null;

        // 添加用户消息到 UI
        _messages.Add(new ChatMessage
        {
            Role = "user",
            Content = userContent,
            Timestamp = DateTime.Now
        });

        // 每次发送前创建新的 CancellationTokenSource，确保可以正确取消
        _cancellationTokenSource?.Dispose();
        _cancellationTokenSource = new CancellationTokenSource();

        _isGenerating = true;
        StateHasChanged();
        await Task.Yield();
        await ScrollToBottom();

        try
        {
            Logger.LogInformation("Sending message to Agent for session {SessionId}", SessionId);

            // 使用流式响应；初始化 SessionParts 以便流式时也按顺序交错渲染
            var assistantMessage = new ChatMessage
            {
                Role = "assistant",
                Content = string.Empty,
                Timestamp = DateTime.Now,
                ToolExecutions = new List<ChatToolExecution>(),
                SessionParts = new List<MessagePartInfo>()
            };
            _messages.Add(assistantMessage);

            await foreach (var chunk in AgentService.SendMessageStreamingAsync(SessionId, userContent, _cancellationTokenSource.Token))
            {
                if (chunk.ToolCallDetails != null)
                {
                    Logger.LogInformation("Tool call detected: {ToolName} with args: {Args}",
                        chunk.ToolCallDetails.Name, chunk.ToolCallDetails.Arguments);

                    assistantMessage.ToolCall = chunk.ToolCallDetails;
                    var existingExecution = assistantMessage.ToolExecutions.LastOrDefault(t =>
                        !string.IsNullOrWhiteSpace(chunk.ToolCallDetails.CallId) &&
                        string.Equals(t.CallId, chunk.ToolCallDetails.CallId, StringComparison.Ordinal));

                    if (existingExecution == null)
                    {
                        existingExecution = new ChatToolExecution
                        {
                            CallId = chunk.ToolCallDetails.CallId ?? string.Empty,
                            Name = chunk.ToolCallDetails.Name,
                            Arguments = chunk.ToolCallDetails.Arguments ?? "{}"
                        };
                        assistantMessage.ToolExecutions.Add(existingExecution);

                        // 仅在新 execution 时添加一次 tool_call part，避免同一工具调用被后端发两次（tool_hint + functionCalls update）导致 IN 重复
                        assistantMessage.SessionParts!.Add(new MessagePartInfo
                        {
                            Type = "tool_call",
                            CallId = chunk.ToolCallDetails.CallId ?? string.Empty,
                            ToolName = chunk.ToolCallDetails.Name ?? string.Empty,
                            Arguments = chunk.ToolCallDetails.Arguments ?? "{}"
                        });
                    }
                    else
                    {
                        existingExecution.Name = chunk.ToolCallDetails.Name;
                        existingExecution.Arguments = chunk.ToolCallDetails.Arguments ?? "{}";
                    }
                }

                if (chunk.IsToolResult)
                {
                    var targetExecution = assistantMessage.ToolExecutions.LastOrDefault(t =>
                        !string.IsNullOrWhiteSpace(chunk.ToolResultCallId) &&
                        string.Equals(t.CallId, chunk.ToolResultCallId, StringComparison.Ordinal))
                        ?? assistantMessage.ToolExecutions.LastOrDefault();

                    if (targetExecution == null)
                    {
                        targetExecution = new ChatToolExecution
                        {
                            CallId = chunk.ToolResultCallId ?? string.Empty,
                            Name = chunk.ToolCallDetails?.Name ?? "tool"
                        };
                        assistantMessage.ToolExecutions.Add(targetExecution);
                    }

                    targetExecution.Output += chunk.Content;
                    targetExecution.IsError = LooksLikeErrorOutput(targetExecution.Output);

                    // 流式时按顺序添加或追加 tool_result part
                    var lastToolResult = assistantMessage.SessionParts!
                        .Select((p, i) => (Part: p, Index: i))
                        .Where(x => x.Part.Type == "tool_result" && string.Equals(x.Part.CallId, chunk.ToolResultCallId, StringComparison.Ordinal))
                        .LastOrDefault();
                    if (lastToolResult.Part != null)
                    {
                        lastToolResult.Part.Output = (lastToolResult.Part.Output ?? "") + chunk.Content;
                        lastToolResult.Part.IsError = LooksLikeErrorOutput(lastToolResult.Part.Output ?? "");
                    }
                    else
                    {
                        assistantMessage.SessionParts.Add(new MessagePartInfo
                        {
                            Type = "tool_result",
                            CallId = chunk.ToolResultCallId ?? string.Empty,
                            ToolName = targetExecution.Name,
                            Output = chunk.Content,
                            IsError = LooksLikeErrorOutput(chunk.Content)
                        });
                    }
                }
                else if (!chunk.IsToolHint)  // tool-hint 块不追加正文内容（正文中的 [TOOL_CALL] 已被过滤）
                {
                    assistantMessage.Content += chunk.Content;

                    // 流式时按顺序添加或追加 text part
                    if (assistantMessage.SessionParts!.Count > 0 && assistantMessage.SessionParts[assistantMessage.SessionParts.Count - 1].Type == "text")
                    {
                        var lastText = assistantMessage.SessionParts[assistantMessage.SessionParts.Count - 1];
                        lastText.Text = (lastText.Text ?? "") + chunk.Content;
                    }
                    else
                    {
                        assistantMessage.SessionParts.Add(new MessagePartInfo
                        {
                            Type = "text",
                            Text = chunk.Content
                        });
                    }
                }

                StateHasChanged();
                await Task.Yield();
                await ScrollToBottom();

                if (chunk.IsComplete)
                {
                    Logger.LogInformation("Message complete for session {SessionId}", SessionId);
                    break;
                }
            }
        }
        catch (OperationCanceledException)
        {
            Logger.LogInformation("Message generation cancelled for session {SessionId}", SessionId);
            Snackbar.Add("已停止生成", Severity.Info);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error sending message for session {SessionId}", SessionId);

            // 获取配置信息用于显示
            var sessionInfo = await SessionService.GetSessionAsync(SessionId);
            var profileId = sessionInfo?.ProfileId ?? "default";

            // 尝试加载配置获取模型信息
            var modelInfo = "";
            try
            {
                var configPath = GetConfigPath();
                if (File.Exists(configPath))
                {
                    var config = await ConfigurationLoader.LoadAsync(configPath, CancellationToken.None);
                    if (config.Llm.Profiles.TryGetValue(profileId, out var profile))
                    {
                        modelInfo = $" [{profile.Provider}: {profile.Model}]";
                    }
                }
            }
            catch
            {
                // 忽略配置加载错误
            }

            Snackbar.Add($"发送失败: {ex.Message} (Profile: {profileId}){modelInfo}", Severity.Error);
        }
        finally
        {
            _cancellationTokenSource?.Dispose();
            _cancellationTokenSource = null;
            _isGenerating = false;
            StateHasChanged();
            await Task.Yield();
            await ScrollToBottom();
        }
    }

    private async Task HandleImageSelected(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file is null)
            {
                return;
            }

            if (!file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
            {
                Snackbar.Add("仅支持图片文件", Severity.Warning);
                return;
            }

            // 从配置读取最大文件大小
            var maxFileSize = GetMaxFileSizeFromConfig();

            // 检查文件大小
            if (file.Size > maxFileSize)
            {
                var maxFileSizeMb = maxFileSize / 1024 / 1024;
                Snackbar.Add($"图片大小超过限制（最大 {maxFileSizeMb}MB）", Severity.Warning);
                return;
            }

            await using var readStream = file.OpenReadStream(GetMaxFileSizeFromConfig());
            _attachedImageUrl = await SaveImageFromStreamAsync(readStream, Path.GetExtension(file.Name));
            Snackbar.Add("图片已添加", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to handle image upload for session {SessionId}", SessionId);
            Snackbar.Add($"图片上传失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task CopyMessage(ChatMessage message)
    {
        var content = BuildCopyContent(message);
        if (string.IsNullOrWhiteSpace(content))
        {
            Snackbar.Add("没有可复制的内容", Severity.Info);
            return;
        }

        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", content);
        Snackbar.Add("已复制", Severity.Success);
    }

    private async Task EditMessage(ChatMessage message)
    {
        if (!message.Role.Equals("user", StringComparison.OrdinalIgnoreCase) || message.SourceIndex < 0)
        {
            return;
        }

        _inputMessage = message.Content;
        await SessionService.DeleteMessagesFromAsync(SessionId, message.SourceIndex);
        await LoadMessages();
        await InvokeAsync(StateHasChanged);
        Snackbar.Add("消息已加载到输入框，编辑后发送", Severity.Info);
    }

    private async Task RetryMessage(ChatMessage message)
    {
        if (!message.Role.Equals("assistant", StringComparison.OrdinalIgnoreCase) ||
            message.RetryFromIndex is null ||
            string.IsNullOrWhiteSpace(message.RetryPrompt))
        {
            Snackbar.Add("无法重试该消息", Severity.Warning);
            return;
        }

        await SessionService.DeleteMessagesFromAsync(SessionId, message.RetryFromIndex.Value);
        await LoadMessages();
        _inputMessage = message.RetryPrompt;
        await SendMessage();
    }

    private async Task DeleteMessage(ChatMessage message)
    {
        if (message.SourceIndex < 0)
        {
            Snackbar.Add("无法删除该消息", Severity.Warning);
            return;
        }

        await SessionService.DeleteMessagesFromAsync(SessionId, message.SourceIndex);
        await LoadMessages();
        Snackbar.Add("已删除该消息及其后续内容", Severity.Success);
    }

    private Task RemoveAttachedImage()
    {
        _attachedImageUrl = null;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task HandlePastedImageDataUrl(string dataUrl, string contentType)
    {
        if (string.IsNullOrWhiteSpace(dataUrl) || !dataUrl.StartsWith("data:", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        try
        {
            var commaIndex = dataUrl.IndexOf(',');
            if (commaIndex < 0)
            {
                return;
            }

            var base64 = dataUrl[(commaIndex + 1)..];
            var bytes = Convert.FromBase64String(base64);
            await using var stream = new MemoryStream(bytes);

            var ext = GetExtensionFromContentType(contentType);
            _attachedImageUrl = await SaveImageFromStreamAsync(stream, ext);
            Snackbar.Add("已粘贴图片", Severity.Success);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to handle pasted image for session {SessionId}", SessionId);
            Snackbar.Add($"粘贴图片失败: {ex.Message}", Severity.Error);
        }
    }

    private async Task<string> SaveImageFromStreamAsync(Stream sourceStream, string? extension)
    {
        try
        {
            var relativePath = await FileStorageService.SaveFileAsync(sourceStream, SessionId, extension);
            return FileStorageService.GetFileUrl(relativePath);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save image for session {SessionId}", SessionId);
            throw;
        }
    }

    private static string GetExtensionFromContentType(string contentType)
    {
        return contentType?.ToLowerInvariant() switch
        {
            "image/png" => ".png",
            "image/jpeg" => ".jpg",
            "image/jpg" => ".jpg",
            "image/webp" => ".webp",
            "image/gif" => ".gif",
            "image/bmp" => ".bmp",
            _ => ".png"
        };
    }

