@page "/settings"
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ILogger<Settings> Logger
@inject IStringLocalizer<Settings> Localizer
@inject ILocalizationService localizationService
@inject IWebUIConfigService webUIConfigService
@using NanoBot.Core.Configuration
@using NanoBot.WebUI.Services
@using Microsoft.Extensions.Localization

<PageTitle>@Localizer["Title"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="settings-container">
    <MudPaper Elevation="1" Class="pa-4">
        <MudText Typo="Typo.h4" Class="mb-4">@Localizer["WebUISettings"]</MudText>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localizer["ServerConfig"]</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTextField @bind-Value="serverConfig.Host"
                                      Label="@Localizer["Host"]"
                                      Variant="Variant.Outlined"
                                      Class="mb-3" />

                        <MudNumericField @bind-Value="serverConfig.Port"
                                        Label="@Localizer["Port"]"
                                        Min="1"
                                        Max="65535"
                                        Variant="Variant.Outlined"
                                        Class="mb-3" />

                        <MudTextField @bind-Value="serverConfig.Urls"
                                      Label="@Localizer["Urls"]"
                                      Variant="Variant.Outlined"
                                      HelperText="@Localizer["UrlsHelper"]"
                                      Class="mb-3" />
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localizer["AuthConfig"]</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSelect @bind-Value="authConfig.Mode"
                                   Label="@Localizer["AuthMode"]"
                                   Variant="Variant.Outlined"
                                   Class="mb-3">
                            <MudSelectItem Value="@("none")">@Localizer["AuthModeNone"]</MudSelectItem>
                            <MudSelectItem Value="@("token")">@Localizer["AuthModeToken"]</MudSelectItem>
                            <MudSelectItem Value="@("password")">@Localizer["AuthModePassword"]</MudSelectItem>
                        </MudSelect>

                        @if (authConfig.Mode == "token")
                        {
                            <MudTextField @bind-Value="authConfig.Token"
                                          Label="@Localizer["Token"]"
                                          Variant="Variant.Outlined"
                                          Class="mb-3" />
                        }

                        @if (authConfig.Mode == "password")
                        {
                            <MudTextField @bind-Value="authConfig.Password"
                                          Label="@Localizer["Password"]"
                                          InputType="InputType.Password"
                                          Variant="Variant.Outlined"
                                          Class="mb-3" />
                        }

                        <MudCheckBox @bind-checked="authConfig.AllowLocalhost"
                                     Label="@Localizer["AllowLocalhost"]"
                                     T="bool"
                                     Class="mb-3" />
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localizer["CorsConfig"]</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudCheckBox @bind-checked="corsConfig.AllowAnyOrigin"
                                     Label="@Localizer["AllowAnyOrigin"]"
                                     T="bool"
                                     Class="mb-3" />

                        @if (!corsConfig.AllowAnyOrigin)
                        {
                            <MudTextField @bind-Value="newCorsOrigin"
                                          Label="@Localizer["AddAllowedOrigin"]"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@Icons.Material.Filled.Add"
                                          OnAdornmentClick="AddCorsOrigin"
                                          Class="mb-3" />

                            @foreach (var origin in corsConfig.AllowedOrigins)
                            {
                                <MudChip Color="Color.Primary"
                                        Class="mr-2 mb-2"
                                        T="string"
                                        OnClose="() => RemoveCorsOrigin(origin)">
                                    @origin
                                </MudChip>
                            }
                        }

                        <MudCheckBox @bind-checked="corsConfig.AllowAnyMethod"
                                     Label="@Localizer["AllowAnyMethod"]"
                                     T="bool"
                                     Class="mb-3" />

                        <MudCheckBox @bind-checked="corsConfig.AllowAnyHeader"
                                     Label="@Localizer["AllowAnyHeader"]"
                                     T="bool"
                                     Class="mb-3" />

                        <MudCheckBox @bind-checked="corsConfig.AllowCredentials"
                                     Label="@Localizer["AllowCredentials"]"
                                     T="bool"
                                     Class="mb-3" />
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localizer["FeaturesConfig"]</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudCheckBox @bind-checked="featuresConfig.FileUpload"
                                     Label="@Localizer["EnableFileUpload"]"
                                     T="bool"
                                     Class="mb-3" />

                        <MudTextField @bind-Value="featuresConfig.MaxFileSize"
                                      Label="@Localizer["MaxFileSize"]"
                                      Variant="Variant.Outlined"
                                      HelperText="@Localizer["MaxFileSizeHelper"]"
                                      Class="mb-3" />

                        <MudTextField @bind-Value="newFileType"
                                      Label="@Localizer["AddFileType"]"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Filled.Add"
                                      OnAdornmentClick="AddFileType"
                                      Class="mb-3" />

                        @foreach (var fileType in featuresConfig.AllowedFileTypes)
                        {
                            <MudChip Color="Color.Secondary"
                                    Class="mr-2 mb-2"
                                    T="string"
                                    OnClose="() => RemoveFileType(fileType)">
                                @fileType
                            </MudChip>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localizer["LocalizationConfig"]</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSelect @bind-Value="localizationConfig.DefaultLanguage"
                                   Label="@Localizer["DefaultLanguage"]"
                                   Variant="Variant.Outlined"
                                   Class="mb-3">
                            <MudSelectItem Value="@("auto")">@Localizer["LanguageAuto"]</MudSelectItem>
                            <MudSelectItem Value="@("zh-CN")">@Localizer["LanguageZhCN"]</MudSelectItem>
                            <MudSelectItem Value="@("en-US")">@Localizer["LanguageEnUS"]</MudSelectItem>
                        </MudSelect>

                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            @Localizer["LanguageChanged"]
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        <div class="d-flex justify-end mt-4">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       Class="mr-2"
                       OnClick="ResetToDefaults">
                @Localizer["ResetToDefaults"]
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveSettings"
                       StartIcon="@Icons.Material.Filled.Save">
                @Localizer["SaveSettings"]
            </MudButton>
        </div>
    </MudPaper>
</MudContainer>

@code {
    private WebUIServerConfig serverConfig = new();
    private WebUIAuthConfig authConfig = new();
    private WebUICorsConfig corsConfig = new();
    private WebUIFeaturesConfig featuresConfig = new();
    private WebUILocalizationConfig localizationConfig = new();

    private string newCorsOrigin = string.Empty;
    private string newFileType = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentSettingsAsync();
    }

    private async Task LoadCurrentSettingsAsync()
    {
        try
        {
            // 从配置服务加载当前设置
            var config = webUIConfigService.GetConfig();

            serverConfig = config.Server;
            authConfig = config.Auth;
            corsConfig = config.Cors;
            featuresConfig = config.Features;
            localizationConfig = config.Localization;

            // 从本地存储加载语言设置（异步）
            var savedLanguage = await localizationService.GetSavedCultureAsync();
            if (!string.IsNullOrEmpty(savedLanguage))
            {
                localizationConfig.DefaultLanguage = savedLanguage;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "加载 WebUI 配置失败");
            Snackbar.Add("加载配置失败：" + ex.Message, Severity.Error);

            // 使用默认值
            serverConfig = new WebUIServerConfig();
            authConfig = new WebUIAuthConfig();
            corsConfig = new WebUICorsConfig();
            featuresConfig = new WebUIFeaturesConfig();
            localizationConfig = new WebUILocalizationConfig();
        }
    }

    private void AddCorsOrigin()
    {
        if (!string.IsNullOrWhiteSpace(newCorsOrigin) &&
            !corsConfig.AllowedOrigins.Contains(newCorsOrigin))
        {
            corsConfig.AllowedOrigins.Add(newCorsOrigin);
            newCorsOrigin = string.Empty;
            StateHasChanged();
        }
    }

    private void RemoveCorsOrigin(string origin)
    {
        corsConfig.AllowedOrigins.Remove(origin);
        StateHasChanged();
    }

    private void AddFileType()
    {
        if (!string.IsNullOrWhiteSpace(newFileType) &&
            !featuresConfig.AllowedFileTypes.Contains(newFileType))
        {
            if (!newFileType.StartsWith("."))
            {
                newFileType = "." + newFileType;
            }
            featuresConfig.AllowedFileTypes.Add(newFileType);
            newFileType = string.Empty;
            StateHasChanged();
        }
    }

    private void RemoveFileType(string fileType)
    {
        featuresConfig.AllowedFileTypes.Remove(fileType);
        StateHasChanged();
    }

    private void ResetToDefaults()
    {
        serverConfig = new WebUIServerConfig();
        authConfig = new WebUIAuthConfig();
        corsConfig = new WebUICorsConfig();
        featuresConfig = new WebUIFeaturesConfig();
        localizationConfig = new WebUILocalizationConfig();
        StateHasChanged();

        Snackbar.Add(Localizer["ResetSuccess"], Severity.Info);
    }

    private async Task SaveSettings()
    {
        try
        {
            // 构建完整的配置对象
            var config = new WebUIConfig
            {
                Server = serverConfig,
                Auth = authConfig,
                Cors = corsConfig,
                Features = featuresConfig,
                Localization = localizationConfig
            };

            // 保存到配置文件
            var success = await webUIConfigService.SaveConfigAsync(config);

            if (success)
            {
                // 保存语言设置到本地存储
                await localizationService.SaveCultureAsync(localizationConfig.DefaultLanguage);

                Snackbar.Add(Localizer["SaveSuccess"], Severity.Success);

                // 提示用户某些设置需要重启才能生效
                Snackbar.Add("注意：服务器和 CORS 设置需要重启 WebUI 才能生效", Severity.Info);
            }
            else
            {
                Snackbar.Add("保存配置失败", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "保存设置失败");
            Snackbar.Add(Localizer["SaveFailed", ex.Message], Severity.Error);
        }
    }
}
