@using NanoBot.Core.Configuration

<div class="nb-channel-config-editor">
    <MudTextField @bind-Value="Config.Token"
                  Label="Bot Token"
                  Variant="Variant.Outlined"
                  HelperText="从 Discord Developer Portal 获取"
                  InputType="InputType.Password"
                  Class="mb-3" />
    
    <MudTextField @bind-Value="Config.GatewayUrl"
                  Label="Gateway URL"
                  Variant="Variant.Outlined"
                  HelperText="Discord WebSocket Gateway 地址"
                  Class="mb-3" />
    
    <MudNumericField @bind-Value="Config.Intents"
                     Label="Intents"
                     Variant="Variant.Outlined"
                     HelperText="Discord Gateway Intents"
                     Class="mb-3" />
    
    <MudText Typo="Typo.subtitle2" Class="mb-2">允许的服务器/频道</MudText>
    <MudTextField @bind-Value="_newAllowFrom"
                  Label="添加允许的服务器/频道"
                  Variant="Variant.Outlined"
                  Adornment="Adornment.End"
                  AdornmentIcon="@Icons.Material.Filled.Add"
                  OnAdornmentClick="AddAllowFrom"
                  Class="mb-2" />
    
    @foreach (var allowFrom in Config.AllowFrom)
    {
        <MudChip Color="Color.Primary"
                Class="mr-2 mb-2"
                T="string"
                OnClose="() => RemoveAllowFrom(allowFrom)">
            @allowFrom
        </MudChip>
    }
</div>

@code {
    [Parameter]
    public DiscordConfig Config { get; set; } = new();
    
    [Parameter]
    public EventCallback<DiscordConfig> ConfigChanged { get; set; }
    
    private string _newAllowFrom = string.Empty;

    private void AddAllowFrom()
    {
        if (!string.IsNullOrWhiteSpace(_newAllowFrom) && 
            !Config.AllowFrom.Contains(_newAllowFrom))
        {
            var list = Config.AllowFrom.ToList();
            list.Add(_newAllowFrom);
            Config.AllowFrom = list;
            _newAllowFrom = string.Empty;
            ConfigChanged.InvokeAsync(Config);
        }
    }

    private void RemoveAllowFrom(string allowFrom)
    {
        var list = Config.AllowFrom.ToList();
        list.Remove(allowFrom);
        Config.AllowFrom = list;
        ConfigChanged.InvokeAsync(Config);
    }
}
